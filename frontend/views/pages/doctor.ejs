<!DOCTYPE html>

<html>

<head>


    <title>Doctor Dashboard</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        tr {
            transition: 0.15s;
        }

        tr:hover {
            background: #f8f9fa;
        }

        .card {
            border: none;
        }

        .badge {
            font-size: 0.9rem;
        }
    </style>

</head>

<body class="bg-light">

    <div class="container py-4">


        <div class="d-flex justify-content-between align-items-center mb-4">

            <h1>
                Doctor Dashboard
            </h1>

            <button id="logoutBtn" class="btn btn-danger">
                Logout
            </button>

        </div>

        <div id="message"></div>

        <div class="card shadow-sm p-3 mb-4">

            <h3>
                Doctor Profile
            </h3>

            <div id="doctorProfile">
                Loading...
            </div>

        </div>

        <div class="row mb-4">

            <div class="col-md-4">

                <div class="card text-center shadow-sm p-3">

                    <h6>
                        Total Prescriptions
                    </h6>

                    <h2 id="totalPrescriptions">
                        0
                    </h2>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card text-center shadow-sm p-3">

                    <h6>
                        Active
                    </h6>

                    <h2 id="activePrescriptions">
                        0
                    </h2>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card text-center shadow-sm p-3">

                    <h6>
                        Used
                    </h6>

                    <h2 id="usedPrescriptions">
                        0
                    </h2>

                </div>

            </div>

        </div>

        <div class="card shadow-sm p-3 mb-4">

            <h3>
                Create Prescription
            </h3>

            <form id="prescriptionForm">

                <div class="mb-3">

                    <input id="drugCode" class="form-control" placeholder="Drug Code">

                </div>

                <div class="mb-3">

                    <input id="stripCount" type="number" class="form-control" placeholder="Strip Count">

                </div>

                <button class="btn btn-primary" type="submit">
                    Create Prescription
                </button>

            </form>

        </div>

        <div class="card shadow-sm p-3">

            <h3>
                My Prescriptions
            </h3>

            <table class="table table-hover align-middle">

                <thead>

                    <tr>

                        <th>
                            Prescription UID
                        </th>

                        <th>
                            Status
                        </th>

                        <th>
                            QR
                        </th>

                    </tr>

                </thead>

                <tbody id="prescriptionTable">

                </tbody>

            </table>

        </div>
        ```

    </div>

    <script src="/js/doctor.js"></script>

</body>

</html>