<!DOCTYPE html>
<html>

<head>

    <title>MedEye</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>

    <nav class="navbar navbar-dark bg-dark">

        <div class="container">

            <span class="navbar-brand mb-0 h1">
                MedEye
            </span>

        </div>

    </nav>

    <section class="py-5 bg-light">

        <div class="container text-center">

            <h1 class="display-4 fw-bold">

                Secure Medicine Verification

            </h1>

            <p class="lead mt-3">

                Prevent counterfeit medicines through
                prescription tracking, QR verification,
                and end-to-end medicine traceability.

            </p>

            <div class="mt-4">

                <a href="/login" class="btn btn-primary btn-lg me-2">
                    Login
                </a>

                <a href="/verify" class="btn btn-success btn-lg">
                    Consumer Portal
                </a>

            </div>

        </div>

    </section>

    <section class="py-5">

        <div class="container">

            <h2 class="text-center mb-5">
                How MedEye Works
            </h2>

            <div class="row text-center">

                <div class="col-md-3">

                    <div class="card p-4 h-100">

                        <h4>
                            Doctor
                        </h4>

                        <p>
                            Creates digital prescriptions
                            with unique QR codes.
                        </p>

                    </div>

                </div>

                <div class="col-md-3">

                    <div class="card p-4 h-100">

                        <h4>
                            Manufacturer
                        </h4>

                        <p>
                            Produces medicine batches
                            and generates strip QR codes.
                        </p>

                    </div>

                </div>

                <div class="col-md-3">

                    <div class="card p-4 h-100">

                        <h4>
                            Consumer
                        </h4>

                        <p>
                            Orders medicine using
                            a prescription.
                        </p>

                    </div>

                </div>

                <div class="col-md-3">

                    <div class="card p-4 h-100">

                        <h4>
                            Verification
                        </h4>

                        <p>
                            Instantly verify
                            medicine authenticity.
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </section>

    <section class="py-5 bg-light">

        <div class="container">

            <h2 class="text-center mb-5">
                Key Features
            </h2>

            <div class="row">

                <div class="col-md-6">

                    <div class="card p-3 mb-3">

                        <h5>
                            QR Verification
                        </h5>

                        <p>
                            Scan prescriptions and medicine strips
                            for instant validation.
                        </p>

                    </div>

                </div>

                <div class="col-md-6">

                    <div class="card p-3 mb-3">

                        <h5>
                            Counterfeit Detection
                        </h5>

                        <p>
                            Identify fake medicines
                            before consumption.
                        </p>

                    </div>

                </div>

                <div class="col-md-6">

                    <div class="card p-3 mb-3">

                        <h5>
                            Prescription Tracking
                        </h5>

                        <p>
                            Track prescriptions from
                            issuance to dispensing.
                        </p>

                    </div>

                </div>

                <div class="col-md-6">

                    <div class="card p-3 mb-3">

                        <h5>
                            Medicine Traceability
                        </h5>

                        <p>
                            Track medicine from
                            manufacturer to consumer.
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </section>

    <footer class="bg-dark text-white text-center py-4">

        <div class="container">

            MedEye © 2026

            <br>

            Secure Medicine Verification System

        </div>

    </footer>

</body>

</html>