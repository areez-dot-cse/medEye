<!DOCTYPE html>
<html>

<head>
    <title>Manufacturer Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        tr {
            transition: 0.15s;
        }

        tr:hover {
            background: #f8f9fa;
        }

        .card {
            border: none;
        }

        .badge {
            font-size: 0.9rem;
        }
    </style>

</head>

<body>

    <div class="container py-4">

        <div class="d-flex justify-content-between mb-4">

            <h1>Manufacturer Dashboard</h1>

            <button id="logoutBtn" class="btn btn-danger">
                Logout
            </button>

        </div>

        <div id="message"></div>

        <div class="card shadow p-3 mb-4">

            <h3>Manufacturer Profile</h3>

            <div id="manufacturerProfile">
                Loading...
            </div>

        </div>

        <div class="row mb-4">

            <div class="col-md-4">

                <div class="card text-center shadow-sm p-3">

                    <h6>
                        Total Batches
                    </h6>

                    <h2 id="totalBatches">
                        0
                    </h2>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card text-center shadow-sm p-3">

                    <h6>
                        Total Strips
                    </h6>

                    <h2 id="totalStrips">
                        0
                    </h2>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card text-center shadow-sm p-3">

                    <h6>
                        Average Batch Size
                    </h6>

                    <h2 id="avgBatchSize">
                        0
                    </h2>

                </div>

            </div>


        </div>


        <div class="card p-3 mb-4">

            <h3>Create Batch</h3>

            <form id="batchForm">

                <div class="mb-2">
                    <input id="drugCode" class="form-control" placeholder="Drug Code">
                </div>

                <div class="mb-2">
                    <input id="stripCount" type="number" class="form-control" placeholder="Strip Count">
                </div>

                <div class="mb-2">
                    <input id="expiryDate" type="date" class="form-control">
                </div>

                <button class="btn btn-success" type="submit">
                    Create Batch
                </button>

            </form>

        </div>

        <div class="card p-3 mb-4">

            <h3>My Batches</h3>

            <table class="table table-hover">

                <thead>
                    <tr>
                        <th>Batch UID</th>
                        <th>Drug Code</th>
                        <th>Strip Count</th>
                        <th>Expiry</th>
                    </tr>
                </thead>

                <tbody id="batchTable"></tbody>

            </table>

        </div>

    </div>

    <script src="/js/manufacturer.js"></script>

</body>

</html>