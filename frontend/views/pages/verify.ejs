<!DOCTYPE html>
<html>

<head>

    <title>MedEye Consumer Portal</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f8f9fa;
        }

        .card {
            border: none;
        }
    </style>

</head>

<body>

    <div class="container py-5">

        <h1 class="mb-4 text-center">
            MedEye Consumer Portal
        </h1>

        <div class="row">

            <div class="col-md-12">

                <div class="card shadow-sm p-3 mb-4">

                    <h3>
                        Order Medicine
                    </h3>

                    <input id="orderPrescriptionUid" class="form-control mb-3" placeholder="Prescription UID">

                    <button id="orderMedicineBtn" class="btn btn-warning">
                        Order Medicine
                    </button>

                </div>

            </div>

            <div class="row">

                <div class="col-md-6">

                    <div class="card shadow-sm p-3 mb-4">

                        <h3>
                            Verify Prescription
                        </h3>

                        <input id="prescriptionUid" class="form-control mb-3" placeholder="Prescription UID">

                        <button id="verifyPrescriptionBtn" class="btn btn-primary">
                            Verify Prescription
                        </button>

                    </div>

                </div>

                <div class="col-md-6">

                    <div class="card shadow-sm p-3 mb-4">

                        <h3>
                            Verify Medicine Strip
                        </h3>

                        <input id="stripUid" class="form-control mb-3" placeholder="Strip UID">

                        <button id="verifyStripBtn" class="btn btn-success">
                            Verify Strip
                        </button>

                    </div>

                </div>

            </div>

        </div>

        <div id="orderResultCard" class="card shadow-sm p-3 mb-4" style="display:none">

            <h3>
                Order Result
            </h3>

            <div id="orderResult"></div>

        </div>

        <div class="card shadow-sm p-3 mb-4">

            <h3>
                Scan QR Code
            </h3>

            <button id="startScannerBtn" class="btn btn-dark mb-3">
                Start Scanner
            </button>

            <div id="reader"></div>

        </div>

        <div id="verificationCard" class="card shadow-sm p-3" style="display:none">

            <h3>
                Verification Result
            </h3>

            <div id="result"></div>

        </div>

    </div>

    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <script src="/js/verify.js"></script>

</body>

</html>