<!DOCTYPE html>
<html>

<head>
    <title>Authority Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        tr {
            transition: 0.15s;
        }

        tr:hover {
            background: #f8f9fa;
        }

        .card {
            border: none;
        }

        .badge {
            font-size: 0.9rem;
        }
    </style>
</head>

<body>

    <div class="container py-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Authority Dashboard</h1>

            <button id="logoutBtn" class="btn btn-danger">
                Logout
            </button>
        </div>

        <div id="message"></div>

        <div class="row mb-4">

            <div class="col-md-4">
                <div class="card text-center shadow-sm p-3">
                    <h6>Total Doctors</h6>
                    <h2 id="totalDoctors">0</h2>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card text-center shadow-sm p-3">
                    <h6>Total Manufacturers</h6>
                    <h2 id="totalManufacturers">0</h2>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card text-center shadow-sm p-3">
                    <h6>Revoked Accounts</h6>
                    <h2 id="revokedAccounts">0</h2>
                </div>
            </div>

        </div>

        <div class="row">

            <div class="col-md-6">

                <div class="card p-3 mb-4">

                    <h3>Register a New Doctor</h3>

                    <form id="doctorForm">

                        <div class="mb-2">
                            <input id="doctorName" class="form-control" placeholder="Doctor Name">
                        </div>

                        <div class="mb-2">
                            <input id="doctorLicense" class="form-control" placeholder="License Number">
                        </div>

                        <div class="mb-2">
                            <input id="doctorEmail" class="form-control" placeholder="Email">
                        </div>

                        <div class="mb-2">
                            <input id="doctorPassword" type="password" class="form-control" placeholder="Password">
                        </div>

                        <button class="btn btn-success" type="submit">
                            Register
                        </button>

                    </form>

                </div>

            </div>

            <div class="col-md-6">

                <div class="card p-3 mb-4">

                    <h3>Register a New Manufacturer</h3>

                    <form id="manufacturerForm">

                        <div class="mb-2">
                            <input id="manufacturerName" class="form-control" placeholder="Company Name">
                        </div>

                        <div class="mb-2">
                            <input id="manufacturerLicense" class="form-control" placeholder="License Number">
                        </div>

                        <div class="mb-2">
                            <input id="manufacturerEmail" class="form-control" placeholder="Email">
                        </div>

                        <div class="mb-2">
                            <input id="manufacturerPassword" type="password" class="form-control"
                                placeholder="Password">
                        </div>

                        <button class="btn btn-success" type="submit">
                            Register
                        </button>

                    </form>

                </div>

            </div>

        </div>

        <div class="card p-3 mb-4">

            <h3>Doctors</h3>

            <table class="table table-bordered">

                <thead>
                    <tr>
                        <th>UID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody id="doctorTable"></tbody>

            </table>

        </div>

        <div class="card p-3">

            <h3>Manufacturers</h3>

            <table class="table table-bordered">

                <thead>
                    <tr>
                        <th>UID</th>
                        <th>Company</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody id="manufacturerTable"></tbody>

            </table>

        </div>

    </div>

    <script src="/js/authority.js"></script>

</body>

</html>